# Public web URL used by Better Auth-generated plumbing.
BETTER_AUTH_URL=http://localhost:3000

# Replace this before exposing the app to the internet.
BETTER_AUTH_SECRET=change-me

# The scaffolded PostgreSQL connection string.
DATABASE_URL=postgresql://biohacker:biohacker@postgres:5432/biohacker

# Private daemon URL used by the server-side /api/control proxy route.
DAEMON_INTERNAL_URL=http://host.docker.internal:4000
