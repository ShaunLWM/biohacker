{
  "name": "@biohacker/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "biome check src package.json tsconfig.json",
    "lint": "biome lint src package.json tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@biohacker/shared": "workspace:*",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/node": "^24.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
